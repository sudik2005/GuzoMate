rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Profile Images: user_photos/{userId}/{filename}
    match /user_photos/{userId}/{allPaths=**} {
      // Anyone signed in can view profile photos (needed for matching)
      allow read: if isSignedIn();
      
      // Only owner can upload/delete
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Chat Attachments: chat_attachments/{matchId}/{filename}
    match /chat_attachments/{matchId}/{allPaths=**} {
       // Only allow if user is in the match (Mocking this check as Storage rules are limited compared to Firestore)
       // For strict security, use Cloud Functions to generate Signed URLs.
       // For now, we allow authenticated users to read/write, but App logic filters access.
       allow read, write: if isSignedIn();
    }
  }
}
