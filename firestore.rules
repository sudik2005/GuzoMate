rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper to check if user is owning the document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Users Collection ---
    // Anyone signed in can read basic profiles (needed for Discovery)
    // Only the user can edit their own profile
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      // Don't allow deletion basically to preserve history, or allow owner
      allow delete: if isOwner(userId); 
      
      // Swipes Sub-collection (Private!)
      match /swipes/{targetId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Active Walkers (Live Location) ---
    // Sensitive Data! Only signed-in users can see nearby walkers.
    match /active_walkers/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOwner(userId);
    }

    // --- Matches & Chat ---
    match /matches/{matchId} {
      // Only allow access if the user is one of the participants
      // We check the 'users' array field we added to the document
      allow read: if isSignedIn() && request.auth.uid in resource.data.users;
      
      // Allow creation if you are one of the users
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.users;
      
      // Allow updating (lastMessage) if participant
      allow update: if isSignedIn() && request.auth.uid in resource.data.users;

      // Messages Sub-collection
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users;
        allow create: if isSignedIn() && 
                      request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users &&
                      request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}
